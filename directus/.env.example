# PostgreSQL (local placeholders)
POSTGRES_DB=fachkundepilot
POSTGRES_USER=fachkunde
POSTGRES_PASSWORD=change_me_strong_password

# Directus crypto keys (generate unique random strings)
DIRECTUS_KEY=replace_with_32_plus_characters
DIRECTUS_SECRET=replace_with_32_plus_characters

# Directus admin bootstrap (change before first production launch)
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=change_me_admin_password

# Public URL used by Directus
DIRECTUS_PUBLIC_URL=http://cms.localhost
