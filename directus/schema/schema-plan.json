{
  "version": 1,
  "project": "FachkundePilot",
  "scope": "Phase 3 schema setup plan",
  "collections": [
    "languages",
    "pages",
    "page_translations",
    "page_sections",
    "section_translations",
    "categories",
    "category_translations",
    "lessons",
    "lesson_translations",
    "pdf_documents",
    "pdf_document_translations",
    "flashcards",
    "flashcard_translations",
    "questions",
    "question_translations",
    "question_options",
    "question_option_translations",
    "calculation_tasks",
    "calculation_task_translations",
    "vocabulary_items",
    "vocabulary_translations",
    "faq_items",
    "faq_translations",
    "pricing_plans",
    "pricing_plan_translations",
    "site_settings",
    "student_profiles",
    "learning_progress"
  ],
  "base_field_conventions": {
    "status": "string enum style where applicable (draft/published/archived)",
    "sort_order": "integer where ordering is needed",
    "is_published": "boolean on translation collections",
    "is_complete": "boolean on translation collections",
    "timestamps": ["created_at", "updated_at"]
  },
  "relations": [
    { "from": "page_translations.page_id", "to": "pages.id", "type": "many_to_one" },
    { "from": "page_translations.language_id", "to": "languages.id", "type": "many_to_one" },
    { "from": "page_sections.page_id", "to": "pages.id", "type": "many_to_one" },
    { "from": "section_translations.section_id", "to": "page_sections.id", "type": "many_to_one" },
    { "from": "section_translations.language_id", "to": "languages.id", "type": "many_to_one" },
    { "from": "category_translations.category_id", "to": "categories.id", "type": "many_to_one" },
    { "from": "category_translations.language_id", "to": "languages.id", "type": "many_to_one" },
    { "from": "lessons.category_id", "to": "categories.id", "type": "many_to_one" },
    { "from": "lesson_translations.lesson_id", "to": "lessons.id", "type": "many_to_one" },
    { "from": "lesson_translations.language_id", "to": "languages.id", "type": "many_to_one" },
    { "from": "pdf_documents.category_id", "to": "categories.id", "type": "many_to_one" },
    { "from": "pdf_document_translations.pdf_document_id", "to": "pdf_documents.id", "type": "many_to_one" },
    { "from": "flashcards.category_id", "to": "categories.id", "type": "many_to_one" },
    { "from": "flashcard_translations.flashcard_id", "to": "flashcards.id", "type": "many_to_one" },
    { "from": "questions.category_id", "to": "categories.id", "type": "many_to_one" },
    { "from": "question_translations.question_id", "to": "questions.id", "type": "many_to_one" },
    { "from": "question_options.question_id", "to": "questions.id", "type": "many_to_one" },
    { "from": "question_option_translations.question_option_id", "to": "question_options.id", "type": "many_to_one" },
    { "from": "calculation_tasks.category_id", "to": "categories.id", "type": "many_to_one" },
    { "from": "calculation_task_translations.calculation_task_id", "to": "calculation_tasks.id", "type": "many_to_one" },
    { "from": "vocabulary_items.category_id", "to": "categories.id", "type": "many_to_one" },
    { "from": "vocabulary_translations.vocabulary_item_id", "to": "vocabulary_items.id", "type": "many_to_one" },
    { "from": "faq_translations.faq_item_id", "to": "faq_items.id", "type": "many_to_one" },
    { "from": "pricing_plan_translations.pricing_plan_id", "to": "pricing_plans.id", "type": "many_to_one" },
    { "from": "student_profiles.directus_user_id", "to": "directus_users.id", "type": "many_to_one" },
    { "from": "student_profiles.preferred_language_id", "to": "languages.id", "type": "many_to_one" },
    { "from": "learning_progress.student_id", "to": "student_profiles.id", "type": "many_to_one" }
  ],
  "roles": [
    "Administrator",
    "Content Manager",
    "Translator",
    "Student",
    "Public"
  ],
  "permission_rules": [
    "Public reads only published and complete public content",
    "Draft and incomplete translations are never public",
    "Student can update own learning_progress records only",
    "Directus admin access requires authentication"
  ]
}
